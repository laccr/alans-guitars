# Template only — copy to .env and fill in real values. Never put real secrets here.

# Required for Tier A (Reverb API). Get one at https://reverb.com/page/api-docs
REVERB_TOKEN=

# Required for LLM tiebreaker and Phase 3 reply classification.
ANTHROPIC_API_KEY=

# SQLite DB path (relative to project root)
GS_DATABASE_URL=sqlite:///./guitar_searcher.db

# Concurrency cap for parallel scraper fan-out
GS_MAX_CONCURRENCY=8

# Per-host rate limit (requests per second)
GS_PER_HOST_RPS=2

# Default User-Agent for HTTP scrapers
GS_USER_AGENT=guitar-searcher/0.1 (+https://example.invalid)

# Log level: DEBUG, INFO, WARNING, ERROR
GS_LOG_LEVEL=INFO

# Phase 2: notification email (SMTP). For Gmail use an App Password.
GS_NOTIFY_FROM=
GS_NOTIFY_TO=
GS_SMTP_HOST=
GS_SMTP_PORT=587
GS_SMTP_USERNAME=
GS_SMTP_PASSWORD=
GS_SMTP_USE_TLS=true
