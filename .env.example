# ╔══════════════════════════════════════════════════════════════════╗
# ║  THIS FILE IS A TEMPLATE. IT IS COMMITTED TO GIT.                ║
# ║  Never put real secrets here. Copy it to `.env` (which IS        ║
# ║  gitignored) and edit `.env` with real values:                   ║
# ║       cp .env.example .env                                       ║
# ╚══════════════════════════════════════════════════════════════════╝

# Required for Tier A (Reverb API). Get one at https://reverb.com/page/api-docs
REVERB_TOKEN=

# Required for LLM tiebreaker and Phase 3 reply classification.
ANTHROPIC_API_KEY=

# SQLite DB path (relative to project root)
GS_DATABASE_URL=sqlite:///./guitar_searcher.db

# Concurrency cap for parallel scraper fan-out
GS_MAX_CONCURRENCY=8

# Per-host rate limit (requests per second)
GS_PER_HOST_RPS=2

# Default User-Agent for HTTP scrapers
GS_USER_AGENT=guitar-searcher/0.1 (+https://example.invalid)

# Log level: DEBUG, INFO, WARNING, ERROR
GS_LOG_LEVEL=INFO

# Phase 2: notification email (SMTP). For Gmail use an App Password.
GS_NOTIFY_FROM=
GS_NOTIFY_TO=
GS_SMTP_HOST=
GS_SMTP_PORT=587
GS_SMTP_USERNAME=
GS_SMTP_PASSWORD=
GS_SMTP_USE_TLS=true

# Phase 3: outreach (Tier D). REQUIRED for any send:
#   GS_OUTREACH_PHYSICAL_ADDRESS — CAN-SPAM requires a real mailing address.
#   GS_OUTREACH_FROM             — defaults to GS_NOTIFY_FROM if empty.
#   GS_OUTREACH_REPLY_TO         — defaults to GS_OUTREACH_FROM.
GS_OUTREACH_FROM=
GS_OUTREACH_REPLY_TO=
GS_OUTREACH_PHYSICAL_ADDRESS=
GS_OUTREACH_COOLDOWN_DAYS=30
GS_OUTREACH_SENDER_NAME=Guitar Searcher

# Phase 3: IMAP for reading replies. Gmail: imap.gmail.com / 993 / use the App Password.
GS_IMAP_HOST=
GS_IMAP_PORT=993
GS_IMAP_USERNAME=
GS_IMAP_PASSWORD=
GS_IMAP_MAILBOX=INBOX
